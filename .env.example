# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tesla?schema=public"

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET="change-me-min-10-chars"
JWT_EXPIRATION=900            # сек (15 хв)
ACCESS_TOKEN_NAME="tesla_access"
REFRESH_JWT_SECRET="change-me-min-10-chars"
REFRESH_JWT_EXPIRATION=2592000 # сек (30 днів)
REFRESH_TOKEN_NAME="tesla_refresh"
PASSWORD_PEPPER="change-me-min-16-characters"
PAYMENT_ENC_KEY="change-me-32-bytes-hex-secret"

# ── Фронти (CORS) ─────────────────────────────────────────
FRONTEND_URL="http://localhost:3040"
ADMIN_URL="http://localhost:3030"

# ── S3-сумісне сховище (Cloudflare R2 / AWS S3) ──────────────
AWS_REGION="auto"                # R2: auto · AWS: напр. eu-north-1
AWS_ACCESS_KEY_ID=               # R2 Access Key ID
AWS_SECRET_ACCESS_KEY=           # R2 Secret Access Key
AWS_S3_BUCKET_NAME="tesla"
AWS_S3_PUBLIC_URL=               # публічний URL бакета / custom domain (R2)
AWS_S3_ENDPOINT=                 # R2: https://<account_id>.r2.cloudflarestorage.com
AWS_S3_FORCE_PATH_STYLE=true     # true для R2

# ── Інтеграції ────────────────────────────────────────────
NOVA_POSHTA_API_KEY=
PAYMENT_PROVIDER=            # liqpay | fondy | wayforpay | monobank
PAYMENT_PUBLIC_KEY=
PAYMENT_PRIVATE_KEY=

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=
SERVICE_EMAIL=
ALLOW_EMAIL_SENDING=false

# ── App ───────────────────────────────────────────────────
PORT=4040
NODE_ENV="development"
LOG_LEVEL="info"
RUN_CRON=false
