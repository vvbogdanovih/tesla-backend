# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tesla?schema=public"

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET="change-me-min-10-chars"
JWT_EXPIRATION=900            # сек (15 хв)
ACCESS_TOKEN_NAME="tesla_access"
REFRESH_JWT_SECRET="change-me-min-10-chars"
REFRESH_JWT_EXPIRATION=2592000 # сек (30 днів)
REFRESH_TOKEN_NAME="tesla_refresh"
PASSWORD_PEPPER="change-me-min-16-characters"

# ── Фронти (CORS) ─────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# ── S3 (медіа) ────────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_PUBLIC_URL=

# ── Інтеграції ────────────────────────────────────────────
NOVA_POSHTA_API_KEY=
PAYMENT_PROVIDER=            # liqpay | fondy | wayforpay | monobank
PAYMENT_PUBLIC_KEY=
PAYMENT_PRIVATE_KEY=

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=
SERVICE_EMAIL=
ALLOW_EMAIL_SENDING=false

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
RUN_CRON=false
